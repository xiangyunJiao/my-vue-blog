# 服务器部署用：复制为 .env 后逐项改成你自己的值
#   cp .env.production.example .env
# 切勿把填好密码/密钥的 .env 提交到 Git

PORT=3000
NODE_ENV=production

# 建议绝对路径，避免 PM2/working directory 不一致找不到库文件
SQLITE_PATH=/var/www/my-vue-blog/backend/data/blog.sqlite

# 生产环境必填，至少 16 字符。生成示例：openssl rand -base64 32
SESSION_SECRET=openssl rand -base64 32

# 仅当数据库里还没有任何用户时，会用下面账号创建首个管理员；已有用户则忽略
ADMIN_EMAIL=admin@你的域名或邮箱
ADMIN_PASSWORD=admin123456

# 浏览器访问博客时地址栏里的「源」，须一致（含 http/https、端口）
# 暂无域名时用公网 IP，例如：http://47.xxx.xxx.xxx
# 多个前端地址用英文逗号分隔，不要有空格
FRONTEND_ORIGIN=http://139.224.247.141

# RSS、sitemap 里的站点链接，与对外访问地址一致，不要末尾斜杠
PUBLIC_SITE_URL=http://139.224.247.141

# 站点默认名（数据库里没有 site_title 时的回退之一，可选）
SITE_NAME=爱编程的小云
