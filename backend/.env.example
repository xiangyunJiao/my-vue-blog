PORT=3000
NODE_ENV=development

# SQLite 数据库文件路径（相对 backend 目录或绝对路径）
SQLITE_PATH=./data/blog.sqlite

# Session（生产环境必须改为强随机字符串）
SESSION_SECRET=change-me-in-production

# 首次空库时创建管理员（仅当 users 表无数据时写入一次）
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=

# 前端地址，用于 CORS；多个用英文逗号分隔，例如同时允许 localhost 与 127.0.0.1
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# 站点公网地址，用于 RSS、sitemap 中的链接
PUBLIC_SITE_URL=http://localhost:5173

# 站点默认标题（数据库无 site_title 或读库失败时的回退；与前端 VITE_SITE_NAME 建议一致）
SITE_NAME=我的博客
